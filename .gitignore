# cachés que python genera al ejecutar el código
__pycache__/
*.py[cod]
*.egg-info/

# entornos virtuales locales de cada desarrollador
venv/
.venv/
env/

# carpetas y archivos que deja pyinstaller al generar el ejecutable
build/
dist/
*.spec

# el ícono se genera desde el logo durante el build, no hace falta versionarlo
assets/logo/logo.ico

# configuración personal de los editores
.vscode/
.idea/

# archivos temporales propios de windows
Thumbs.db
Desktop.ini
